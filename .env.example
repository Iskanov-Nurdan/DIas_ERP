# ——— Django Core ———
DJANGO_SECRET_KEY=django-insecure-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ——— База данных (если не указан PGDATABASE — используется SQLite) ———
PGDATABASE=dias
PGUSER=dias_user
PGPASSWORD=changeme
PGHOST=localhost
PGPORT=5432

# ——— CORS ———
FRONTEND_PORT=3000
# Для локальной разработки Vite обычно использует 5173; можно указать несколько портов.
FRONTEND_PORTS=3000,5173
# В prod — строгий whitelist через запятую
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ——— Статика (prod) ———
# STATIC_ROOT=/var/www/dias/static
